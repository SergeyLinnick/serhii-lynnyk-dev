{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["DATABASE_URL", "DATABASE_URL_UNPOOLED"],
	"tasks": {
		"build": {
			"dependsOn": ["^build", "^db:generate"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"lint": {},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:push": {
			"cache": false
		}
	}
}
