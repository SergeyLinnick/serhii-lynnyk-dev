{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": [
		"CI",
		"DATABASE_URL",
		"DATABASE_URL_UNPOOLED",
		"NEXT_PUBLIC_SENTRY_DSN",
		"NEXT_RUNTIME",
		"NODE_ENV",
		"SENTRY_AUTH_TOKEN",
		"SENTRY_ORG",
		"SENTRY_PROJECT"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build", "^db:generate"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"lint": {},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:push": {
			"cache": false
		}
	}
}
